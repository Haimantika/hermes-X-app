{
  "name": "slopscore",
  "version": "0.1.0",
  "private": true,
  "description": "SlopScore — the Turing test for your timeline. Score the verbal tics of AI writing and roast them with receipts.",
  "type": "module",
  "bin": {
    "slopscore": "./dist/cli.js"
  },
  "scripts": {
    "web": "tsx src/web/server.ts",
    "dev": "tsx watch src/web/server.ts",
    "mcp": "tsx src/mcp/server.ts",
    "bot": "tsx src/bot/index.ts",
    "score": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts --demo",
    "cron": "tsx src/cron.ts",
    "convex": "convex dev",
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "node -e \"require('fs').cpSync('src/integrations/emoji','dist/integrations/emoji',{recursive:true})\"",
    "start": "node dist/web/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-js": "^2.6.2",
    "convex": "^1.17.3",
    "dotenv": "^16.4.7",
    "grammy": "^1.30.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
