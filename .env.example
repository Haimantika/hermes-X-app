# ─────────────────────────────────────────────────────────────
# SlopScore config. Copy to .env and fill what you have.
# EVERY integration degrades gracefully: leave a key blank and
# that capability runs in mock mode so the whole app still demos.
# ─────────────────────────────────────────────────────────────

# Public URL used on the verdict card (anti-spoof: link travels with the screenshot)
PUBLIC_APP_URL=https://slopscore.app

# --- Web app ---
PORT=3000

# --- Hermes Agent (MANDATORY scoring path) ---
# The webapp scores each handle THROUGH Hermes: it runs `hermes -z "<task>"`,
# and Hermes calls the SlopScore MCP tools (see hermes.config.example.yaml).
#   auto   = use the hermes CLI if it's on PATH, else run the engine directly
#   cli    = always use hermes (fail loudly if unavailable) — use for the demo
#   direct = never use hermes (dev / no install)
HERMES_MODE=auto
HERMES_BIN=hermes
HERMES_TIMEOUT_MS=120000

# --- Telegram (grammy) — OPTIONAL secondary surface ---
# Get from @BotFather. Blank = bot won't start (use the webapp instead).
TELEGRAM_BOT_TOKEN=

# --- LinkUp (tweet retrieval) ---
# https://www.linkup.so — blank = deterministic mock tweets are used.
LINKUP_API_KEY=

# --- ElevenLabs (voice-read the roast) ---
# Blank = a silent/placeholder clip is written so the pipeline still completes.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# --- Image gen for the card background (OPTIONAL) ---
# The card is drawn deterministically as SVG->PNG regardless. If set, an
# AI background is generated behind the receipts. Blank = clean gradient.
OPENAI_API_KEY=
IMAGE_GEN_MODEL=gpt-image-1

# --- Convex (shared leaderboard + score-history memory) ---
# Run `npx convex dev` to get this. Blank = local JSON store in .data/.
CONVEX_URL=
